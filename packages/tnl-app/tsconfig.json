{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "baseUrl": "../../",
    "paths": {
      "@/*": ["src/*"],
      "@tnl/canvas-interface": ["packages/canvas-interface/src/index.ts"],
      "@tnl/canvas-interface/*": ["packages/canvas-interface/src/*"],
      "@tnl/app": ["packages/tnl-app/src/index.ts"],
      "@tnl/app/*": ["packages/tnl-app/src/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.d.ts",
    "../../src/ui/jsx.d.ts",
    "../../src/richtext-intrinsics.d.ts"
  ]
}