{
  "compilerOptions": {
    "target": "esnext",
    "lib": ["esnext", "DOM", "DOM.Iterable"],
    "module": "esnext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "paths": {
      "@/*": ["packages/tnl-app/src/*"],
      "@tnl/canvas-interface": ["packages/canvas-interface/src/index.ts"],
      "@tnl/canvas-interface/*": ["packages/canvas-interface/src/*"],
      "@tnl/app": ["packages/tnl-app/src/index.ts"],
      "@tnl/app/*": ["packages/tnl-app/src/*"]
    },
    "jsx": "react",
    "jsxFactory": "createElement",
    "jsxFragmentFactory": "Fragment",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": []
  },
  "include": ["packages/**/*.ts", "packages/**/*.tsx", "packages/**/*.d.ts"]
}
